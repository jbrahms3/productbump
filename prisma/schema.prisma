generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id               String    @id @default(cuid())
  name             String
  tagline          String
  description      String
  websiteUrl       String
  logoUrl          String?
  makerName        String
  makerEmail       String
  makerUserId      String?   // Clerk user id of the submitter
  slug             String    @unique

  // Stripe integration fields
  stripeRestrictedKey      String?   // maker's restricted API key
  stripeWebhookSecret      String?   // signing secret for this product's webhook
  stripeWebhookEndpointId  String?   // so we can delete/re-register the webhook
  stripeConnected          Boolean   @default(false)

  // Revenue / bump tracking (amounts in cents)
  revenueAmount    Int       @default(0)      // total new revenue generated, in cents
  revenueThreshold Int       @default(10000)  // $100 goal to bump off homepage
  bumped           Boolean   @default(false)  // graduated off homepage
  bumpedAt         DateTime?

  // Homepage position
  featured         Boolean   @default(false)  // visible on homepage (one of 8 slots)
  featuredAt       DateTime  @default(now())
  randomSlot       Boolean   @default(false)  // this slot pulls a random product from the queue on bump, instead of FIFO

  // Category tag
  category         String    @default("Productivity")

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  payments         Payment[]
}

model Payment {
  id              String   @id @default(cuid())
  stripeChargeId  String   @unique
  amount          Int      // amount in cents (one-time purchase or subscription invoice)
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  createdAt       DateTime @default(now())
}
